# Gemini API Key（必填，用於翻譯 + 語音辨識）
GEMINI_API_KEY=your-gemini-api-key

# JWT Secret（必填，用於驗證）
JWT_SECRET=your-jwt-secret-change-this

# 預設 Host 帳號（阿峰老師）
HOST_EMAIL=ai@autolab.cloud
HOST_PASSWORD=changeme
HOST_NAME=阿峰老師

# 資料目錄（選填，預設 ./data）
DATA_DIR=./data

# CORS 允許來源（選填，逗號分隔）
ALLOWED_ORIGINS=http://localhost:5173

# 連接埠（選填，預設 3000）
PORT=3000
